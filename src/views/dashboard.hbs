<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alaga</title>
    <link href="/output.css" rel="stylesheet" />
</head>

<body class="bg-zinc-950 text-white min-h-screen p-6">

    <p class="text-xs text-orange-500 uppercase tracking-widest mb-1">Fleet Overview</p>
    <h1 class="text-4xl font-semibold text-white mb-6">Dashboard</h1>

    {{!-- Stat Cards --}}
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
        <div class="bg-zinc-900 rounded-lg p-4">
            <p class="text-xs text-zinc-500 uppercase tracking-widest mb-1">Total</p>
            <p class="text-3xl font-semibold text-white">{{stats.total}}</p>
        </div>
        <div class="bg-green-950 rounded-lg p-4">
            <p class="text-xs text-green-600 uppercase tracking-widest mb-1">Good</p>
            <p class="text-3xl font-semibold text-green-400">{{stats.good}}</p>
        </div>
        <div class="bg-amber-950 rounded-lg p-4">
            <p class="text-xs text-amber-600 uppercase tracking-widest mb-1">Warning</p>
            <p class="text-3xl font-semibold text-amber-400">{{stats.warning}}</p>
        </div>
        <div class="bg-red-950 rounded-lg p-4">
            <p class="text-xs text-red-600 uppercase tracking-widest mb-1">Overdue</p>
            <p class="text-3xl font-semibold text-red-400">{{stats.overdue}}</p>
        </div>
    </div>

    {{!-- Bike Cards --}}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {{#each bikes}}
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden">
            <div class="h-1" style="background-color: {{accentColor}}"></div>
            <div class="p-5">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <p class="text-xs text-zinc-500 uppercase tracking-widest">{{brand}}</p>
                        <h2 class="text-xl font-semibold text-white mt-0.5">{{model}}</h2>
                        <p class="text-xs text-zinc-500 font-mono mt-1">{{year}} · {{plateNumber}}</p>
                    </div>
                    <span class="text-xs px-2.5 py-1 rounded-full border font-mono {{statusClass}}">
                        {{status}}
                    </span>
                </div>
                <hr class="border-zinc-800 mb-4" />
                <p class="text-xs text-zinc-500 uppercase tracking-widest">Current odometer</p>
                <p class="text-2xl font-semibold text-white font-mono">
                    {{currentOdometer}} <span class="text-sm font-normal text-zinc-500">km</span>
                </p>
                <div class="mt-4">
                    <div class="flex justify-between text-xs mb-1.5">
                        <span class="text-zinc-500 uppercase tracking-widest">Oil change</span>
                        <span class="font-mono {{progressHintClass}}">{{progressHint}}</span>
                    </div>
                    <div class="h-1.5 bg-zinc-800 rounded-full overflow-hidden">
                        <div class="h-full rounded-full"
                            style="width: {{progressPct}}%; background-color: {{accentColor}}"></div>
                    </div>
                </div>
            </div>
            <div class="border-t border-zinc-800 px-5 py-3 flex justify-between">
                <a href="/bike/{{id}}" class="text-xs text-zinc-500 hover:text-white font-mono">View history →</a>
                <a href="/add?bikeId={{id}}" class="text-xs text-zinc-500 hover:text-white font-mono">Log entry +</a>
            </div>
        </div>
        {{/each}}
    </div>

</body>

</html>